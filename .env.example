# ─── Datenbank ────────────────────────────────────────────────
# Lokal:
DATABASE_URL="postgresql://novarix_user:SICHERES_PASSWORT@localhost:5432/novarix_db?schema=public"
# Railway: wird automatisch gesetzt. Falls Connection Pooling aktiv:
# DATABASE_URL = pooled connection string (mit pgbouncer)
# DIRECT_URL  = direkte Verbindung (für Migrationen)
DIRECT_URL=""

# ─── JWT Secrets (mindestens 64 Zeichen, zufällig generiert) ──
JWT_SECRET="HIER_EIN_LANGER_ZUFALLSSTRING_MINDESTENS_64_ZEICHEN_GENERIEREN"
JWT_REFRESH_SECRET="HIER_EIN_ANDERER_LANGER_ZUFALLSSTRING_MINDESTENS_64_ZEICHEN"

# ─── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS — Frontend URL(s), kommagetrennt für mehrere ───────
# Lokal:
CORS_ORIGIN="http://localhost:4200"
# Railway: z.B. "https://novarix-frontend.railway.app,http://localhost:4200"

# ─── Admin-Account (wird beim ersten Start erstellt) ──────────
ADMIN_EMAIL="maxnodes@gmail.com"
ADMIN_PASSWORD="SICHERES_ADMIN_PASSWORT_HIER_SETZEN"
ADMIN_NAME="Max"
